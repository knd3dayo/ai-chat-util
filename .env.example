# Secrets only (.env is optional)
#
# 推奨: APIキーを LLM_API_KEY に統一し、ai-chat-util-config.yml / autonomous-agent-util-config.yml から
# `os.environ/LLM_API_KEY` で参照します。

# OpenAI（推奨: 1本化）
LLM_API_KEY=******************

# --- 互換/別運用（必要な場合のみ） ---
# OpenAI（provider別に分けたい場合）
# OPENAI_API_KEY=******************

# Azure OpenAI
# AZURE_API_KEY=******************

# Anthropic
# ANTHROPIC_API_KEY=******************

# AWS Bedrock
# AWS_ACCESS_KEY_ID=******************
# AWS_SECRET_ACCESS_KEY=******************
# AWS_REGION=ap-northeast-1

