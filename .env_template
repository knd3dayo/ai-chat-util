# .env_template
#
# 方針:
# - 秘密情報（APIキー/トークン）のみを .env / 環境変数に置きます
# - それ以外の設定は config.yml に移しました（config.example.yml を参照）
#
# 例:
#   copy .env_template .env
#   copy config.example.yml config.yml

# OpenAI
OPENAI_API_KEY=

# Azure OpenAI
AZURE_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# AWS Bedrock (if used)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
