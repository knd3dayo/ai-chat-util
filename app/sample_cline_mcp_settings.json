{
    "mcpServers": {
        "AIChatUtil": {
            "timeout": 60,
            "type": "stdio",
            "command": "uv",
            "args": [
                "--directory",
                "<REPO_PATH>",
                "run",
                "-m",
                "ai_chat_util.mcp.mcp_server"
            ],
            "env": {
                "LLM_API_KEY": "sk-****",
                "AI_CHAT_UTIL_CONFIG": "<REPO_PATH>\\ai-chat-util-config.yml"
            }
        }
    }
}