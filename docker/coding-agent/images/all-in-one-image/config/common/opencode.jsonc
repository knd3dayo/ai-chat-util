{
    "$schema": "https://opencode.ai/config.json",
    "enabled_providers": ["litellm"],
    "provider": {
      "litellm": {
        "npm": "@ai-sdk/openai-compatible",
        "name": "LiteLLM Proxy",
        "options": {
          "baseURL": "https://litellm:4000/v1"
        },
        "models": {
          "poc-chat-model": {
            "name": "poc-chat-model"
          }
        }
      }
    },
    "mcp": {
    "ai-chat-util": {
      "enabled": true,
      "timeout": 60000,
      "type": "local",
      "command":["uv", "--directory", "{env:HOME}/data/mcps/ai-chat-util/app", "run", "--no-sync", "python", "-m", "ai_chat_util.mcp.mcp_server"],
      "environment": {
        "LLM_PROVIDER": "litellm",
        "COMPLETION_MODEL": "poc-chat-model",
        "OPENAI_API_KEY": "sk-poc-master-key-12345",
        "OPENAI_BASE_URL": "http://litellm:4000"
      }
    },
    "denodo-log-util": {
      "enabled": true,
      "timeout": 60000,
      "type": "local",
      "command":["uv", "--directory", "{env:HOME}/data/mcps/deonodo-log-util", "run", "--no-sync", "python", "-m", "denodo_log_util.mcp.mcp_server"]
    }

  }
}