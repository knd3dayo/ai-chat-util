{
  "mcpServers": {
    "AssuranceProxy": {
      "disabled": false,
      "timeout": 60,
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "-m",
        "ai_chat_util.mcp.mcp_server",
        "--config",
        "ai-chat-util-config.yml",
        "--log_level",
        "INFO",
        "--log_file",
        "mcp_server.log"
      ],
      "env": {
        "LLM_API_KEY": "os.environ/LLM_API_KEY"
      }
    }
  }
}